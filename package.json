{
  "name": "agenticdome-sdk",
  "version": "0.5.2",
  "description": "TypeScript SDK for AgenticDome AI security, guardrails, trust, A2A, MCP, and enterprise SaaS scanning APIs",
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/agenticdome/agenticdome-sdk-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agenticdome/agenticdome-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/agenticdome/agenticdome-sdk-ts/issues"
  },
  "keywords": [
    "agentguard",
    "guardrails",
    "ai-security",
    "a2a",
    "mcp",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
